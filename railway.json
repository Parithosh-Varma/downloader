{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "python3 -m pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "gunicorn main:app --bind 0.0.0.0:$PORT --workers 2 --timeout 300",
    "healthcheckPath": "/",
    "restartPolicyType": "on_failure"
  }
}
